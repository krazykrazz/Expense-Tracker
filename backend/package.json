{
  "name": "expense-tracker",
  "version": "1.5.1",
  "description": "Full-stack Expense Tracker Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd client && npm install && npm run build",
    "db:check": "node scripts/checkDatabaseSchema.js",
    "db:migrate": "node scripts/addFixedExpensesTable.js",
    "test": "cross-env NODE_ENV=test jest --runInBand",
    "test:parallel": "cross-env NODE_ENV=test jest --maxWorkers=75%",
    "test:fast": "cross-env NODE_ENV=test FAST_CHECK_NUM_RUNS=10 jest --runInBand",
    "test:fast:parallel": "cross-env NODE_ENV=test FAST_CHECK_NUM_RUNS=10 jest --maxWorkers=75%",
    "test:unit": "cross-env NODE_ENV=test jest --runInBand --testPathIgnorePatterns=pbt",
    "test:unit:parallel": "cross-env NODE_ENV=test jest --maxWorkers=75% --testPathIgnorePatterns=pbt",
    "test:unit:ci": "cross-env NODE_ENV=test CI=true jest --bail --testPathIgnorePatterns=pbt",
    "test:pbt": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=pbt",
    "test:pbt:parallel": "cross-env NODE_ENV=test jest --maxWorkers=75% --testPathPatterns=pbt",
    "test:pbt:ci": "cross-env NODE_ENV=test CI=true FAST_CHECK_NUM_RUNS=15 jest --bail --testPathPatterns=pbt",
    "test:backup": "cross-env NODE_ENV=test jest --runInBand --testPathPatterns=\"backup.*\\.(integration|pbt)\\.test\"",
    "test:backup:ci": "cross-env NODE_ENV=test CI=true FAST_CHECK_NUM_RUNS=15 jest --bail --runInBand --testPathPatterns=\"backup.*\\.(integration|pbt)\\.test\"",
    "test:ci": "cross-env NODE_ENV=test CI=true FAST_CHECK_NUM_RUNS=15 jest --bail"
  },
  "jest": {
    "testTimeout": 30000,
    "globalSetup": "<rootDir>/jest.globalSetup.js",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "testEnvironment": "node",
    "verbose": false,
    "forceExit": true
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "sqlite3": "^6.0.1",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "baseline-browser-mapping": "^2.10.18",
    "cross-env": "^10.1.0",
    "fast-check": "^4.6.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
